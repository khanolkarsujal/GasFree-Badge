# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# Comma-separated origins for CORS (frontend URL when you wire it later)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Session signing secret — use 32+ random bytes in production
JWT_SECRET=change_me_to_a_long_random_string_in_production

# SIWE domain must match what clients sign
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3001

# ── Chain (Base Sepolia) ───────────────────────────────────────────────────────
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

TYI_TOKEN_ADDRESS=0x9b9deeea99C2B77c0e7F7bdCf0a01a0F0843e5DD
BADGE_CONTRACT_ADDRESS=0x866d057Af43F711d7C3023fdCBFC474C4B12F187
WALLET_CONTRACT_ADDRESS=

# Optional: start block for indexer (0 = from genesis — slow on mainnet forks)
INDEXER_START_BLOCK=0
INDEXER_POLL_MS=12000

# SQLite database path (created automatically)
DATABASE_PATH=./data/wallet.db
