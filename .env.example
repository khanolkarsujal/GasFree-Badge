# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Required for testnet deployment ──────────────────────────────────────────
# Your wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC URL — free options:
#   Alchemy:  https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
#   Infura:   https://base-sepolia.infura.io/v3/YOUR_KEY
#   Public:   https://sepolia.base.org  (no key, rate-limited)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Required for Basescan contract verification ───────────────────────────────
# Get a free API key at https://basescan.org/register
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to print a gas usage table after tests
REPORT_GAS=false

# CoinMarketCap key for USD gas cost estimates in the gas report
COINMARKETCAP_API_KEY=
