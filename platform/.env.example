# App API
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# PostgreSQL (app metadata)
DATABASE_URL=postgresql://gasfree:gasfree@localhost:5433/gasfree

# Redis (sessions, rate limits, idempotency cache)
REDIS_URL=redis://localhost:6379

# JWT (use 64+ char secret in production)
JWT_SECRET=replace_with_openssl_rand_hex_64
JWT_EXPIRES_IN=24h

# CORS (comma-separated origins for the React app)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://gas-free-badge.vercel.app

# Dev top-up (POST /v1/balance/topup — requires X-Topup-Secret header)
TOPUP_SECRET=dev_topup_change_me
ALLOW_DEV_TOPUP=true

# SIWE (Sign-In With Ethereum — EIP-4361)
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3001

# Formance Ledger (github.com/formancehq/ledger)
FORMANCE_LEDGER_URL=http://localhost:3068
FORMANCE_LEDGER_NAME=gasfree
FORMANCE_ASSET=TYI/18

# Base Sepolia / on-chain settlement
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
TYI_TOKEN_ADDRESS=0x9b9deeea99C2B77c0e7F7bdCf0a01a0F0843e5DD
BADGE_CONTRACT_ADDRESS=0x866d057Af43F711d7C3023fdCBFC474C4B12F187
WALLET_CONTRACT_ADDRESS=
